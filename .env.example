# TARS REVOKE stores all mutable state locally and never commits this file.
TARS_DATA_DIR=.tars
TARS_BIND_HOST=127.0.0.1
TARS_BIND_PORT=8747

# Optional. Discovery checks official Codex app bundles before PATH.
TARS_CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex

# Leave blank to use the default model supported by the current Codex
# authentication, or set a model name that your Codex account can access.
TARS_CODEX_MODEL=
TARS_CODEX_TIMEOUT_SECONDS=900

# OPENAI_API_KEY or CODEX_API_KEY may be supplied for API-key automation. TARS
# allowlists either name only for the Codex subprocess; Git, tests, experiments,
# and the schema registry never inherit them. Never place a key in this file.
